<script>
(function(){
  function show(name){
    var ok=false;
    document.querySelectorAll('.route').forEach(function(r){var on=r.getAttribute('data-route')===name;r.classList.toggle('active',on);if(on)ok=true;});
    if(!ok){var h=document.querySelector('.route[data-route="home"]');if(h){h.classList.add('active');}name='home';}
    window.scrollTo(0,0);
    document.querySelectorAll('.route.active .reveal').forEach(function(el){el.classList.add('in');});
  }
  function cur(){return ((location.hash||'#home').replace('#','').split('?')[0])||'home';}
  window.addEventListener('hashchange',function(){show(cur());});
  show(cur());
})();
</script>

