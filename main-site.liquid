<main class="pg">
  <section class="pg-head">
    <div class="wrap">
      <div class="eyebrow"><span class="dot"></span>Servizi</div>
      <h1 class="h-display">Cosa <span class="it">faccio</span>.</h1>
      <p class="lead" style="max-width:52ch">Due servizi complementari. Inizia con la valutazione per capire da dove parti, poi continuiamo con un piano d'allenamento se sei pronta a metterti in gioco.</p>
    </div>
  </section>

  <!-- Servizio 01 -->
  <section class="sv-detail right">
    <div class="wrap inner">
      <div class="sv-text reveal">
        <div class="sv-num">— 01</div>
        <h2 class="h-1">Valutazione Funzionale.</h2>
        <p class="lead">Una sessione completa per mappare il tuo corpo e definire gli obiettivi.</p>
        <div class="sv-lbl">Include</div>
        <ul class="sv-incl">
          <li><i></i>Anamnesi e raccolta delle abitudini</li>
          <li><i></i>Test posturali e di mobilità</li>
          <li><i></i>Valutazione della forza e dell'equilibrio</li>
          <li><i></i>Identificazione di compensi e limitazioni</li>
          <li><i></i>Piano d'azione personalizzato</li>
          <li><i></i>Report scritto inviato entro 48h</li>
        </ul>
        <div class="sv-lbl">Modalità</div>
        <div class="sv-modes">
          <span>Online via videochiamata</span><span>In presenza · Padova</span><span>· Bologna</span><span>· Milano</span><span>· Torino</span>
        </div>
        <a href="#booking" class="btn-gold">Prenota la valutazione →</a>
      </div>
      <div class="sv-media">
        <div class="ph" data-label="silhouette body scan" data-tone="accent"></div>
        <div class="meta"><span>file · 01</span><span>45–60 min</span></div>
        <div class="price">€80</div>
      </div>
    </div>
  </section>

  <!-- Servizio 02 -->
  <section class="sv-detail left paper">
    <div class="wrap inner">
      <div class="sv-media dark">
        <div class="ph" data-label="dumbbell still life" data-tone="dark"></div>
        <div class="meta"><span>file · 02</span><span>4 sett. → 6 mesi</span></div>
        <div class="price">da €120</div>
      </div>
      <div class="sv-text reveal">
