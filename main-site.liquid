<main id="top">

<!-- ───────────────── ACT 1 · HERO (cinematic) ───────────────── -->
<section class="hero is-dark" id="hero">
  <div class="hero-sticky" id="heroSticky">
    <div class="hero-grain"></div>
    <div class="hero-orb" id="heroOrb"></div>

    <div class="hero-sil" id="heroSil"><img src="{{ 'g09.svg' | asset_url }}" alt="Silhouette femminile" /></div>

    <!-- headline (first) -->
    <div class="hero-h"><div class="wrap"><h1 id="heroHeadline">
      <span class="w" data-s="0.50" data-e="0.55">Ascolta</span>
      <span class="w" data-s="0.51" data-e="0.56">il</span>
      <span class="w" data-s="0.52" data-e="0.57">tuo</span><br>
      <span class="w accent" data-s="0.54" data-e="0.60">corpo</span><span class="w tight" data-s="0.55" data-e="0.60">,</span>
      <span class="w" data-s="0.56" data-e="0.61">agisci</span><br>
      <span class="w" data-s="0.58" data-e="0.63">con</span>
      <span class="w accent" data-s="0.60" data-e="0.65">cura</span><span class="w tight" data-s="0.62" data-e="0.66">.</span>
    </h1></div></div>

    <!-- greeting (after headline) -->
    <div class="hero-greet" id="heroGreet"><div class="wrap"><div class="script">{{ section.settings.hero_greet | default: 'ciao, sono Maria —' }}</div></div></div>

    <!-- subhead -->
    <div class="hero-sub" id="heroSub"><div class="wrap"><p>{{ section.settings.hero_sub | default: 'Per chi non vuole un programma generico — ma <span class="hl">il suo</span>.' }}</p></div></div>

    <!-- proposal + CTA -->
    <div class="hero-cta" id="heroCta"><div class="wrap">
      <div class="kicker">{{ section.settings.hero_kicker | default: 'Iniziamo da qui ↓' }}</div>
      <div class="row">
        <a href="{{ section.settings.hero_cta_link | default: '#booking' }}" class="btn-gold">{{ section.settings.hero_cta_text | default: 'Prenota la valutazione funzionale →' }}</a>
        <span class="note">{{ section.settings.hero_cta_note | default: '60 min online · 45 in studio. Il primo passo per capire da dove partire.' }}</span>
      </div>
    </div></div>

    <div class="hero-cue" id="heroCue"><span class="hero-cue__label">Scorri per scoprire</span><span class="hero-cue__chevs" aria-hidden="true"><i></i><i></i></span></div>
  </div>
</section>

<!-- ───────────────── ACT 3 · NUMBERS ───────────────── -->
<section class="numbers">
  <img class="decor a" src="{{ 'g04.svg' | asset_url }}" alt="" />
  <img class="decor b" src="{{ 'g13.svg' | asset_url }}" alt="" />
  <div class="wrap">
    <div class="eyebrow" style="justify-content:center;margin-bottom:12px"><span class="dot"></span>Numeri</div>
    <h2 class="h-display">Tredici anni di <span class="it" style="color:var(--accent)">movimento</span>.</h2>
    <div class="numbers__grid">
      <div class="numbers__cell"><div class="numbers__big"><span class="count" data-to="300" data-suffix="+">0</span></div><div class="numbers__lbl">persone seguite</div><div class="numbers__det">in tutta Italia</div></div>
      <div class="numbers__cell"><div class="numbers__big"><span class="count" data-to="13">0</span></div><div class="numbers__lbl">anni di pratica</div><div class="numbers__det">dal 2013</div></div>
      <div class="numbers__cell"><div class="numbers__big"><span class="count" data-to="4">0</span></div><div class="numbers__lbl">città italiane</div><div class="numbers__det">più online</div></div>
      <div class="numbers__cell"><div class="numbers__big"><span class="count" data-to="1">0</span></div><div class="numbers__lbl">obiettivo</div><div class="numbers__det">il tuo</div></div>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 4 · CITIES ───────────────── -->
<section class="cities" id="cities">
  <div class="cities__glow"></div>
  <div class="wrap">
    <div class="cities__grid">
      <div>
        <div class="eyebrow"><span class="dot"></span>Ovunque tu sia</div>
        <h2 class="h-display">In <span class="it">presenza</span>,<br>o ovunque.</h2>
        <p class="cities__intro">Quattro città italiane, una agenda mensile. Per il resto, ci vediamo online — stessa cura, stessa profondità.</p>
        <a href="#booking" class="btn-outline-gold">Trova il tuo slot →</a>
        <p class="cities__more">La tua città non c'è? <button class="cities__more-btn" type="button" data-citta-request>Candida la tua provincia →</button></p>
      </div>
      <div class="cities__list" id="cityList" data-dynamic>
        <!-- Riempita da cities-hydrate.js leggendo /api/locations (solo sedi active) -->
        <noscript>
          <button class="city-row" data-citta-request="Padova (PD)"><div><div class="name">Padova</div><div class="meta">PD · Veneto</div></div><div class="note">Richiedi una data →</div></button>
          <button class="city-row" data-citta-request="Bologna (BO)"><div><div class="name">Bologna</div><div class="meta">BO · Emilia-Romagna</div></div><div class="note">Richiedi una data →</div></button>
          <button class="city-row" data-citta-request="Milano (MI)"><div><div class="name">Milano</div><div class="meta">MI · Lombardia</div></div><div class="note">Richiedi una data →</div></button>
          <button class="city-row" data-citta-request="Torino (TO)"><div><div class="name">Torino</div><div class="meta">TO · Piemonte</div></div><div class="note">Richiedi una data →</div></button>
          <button class="city-row"><div><div class="name">Online</div><div class="meta">Ovunque tu sia</div></div><div class="note">Videochiamata · sempre</div></button>
        </noscript>
      </div>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 5 · METHOD ───────────────── -->
<section class="method" id="method">
  <img class="leaf" src="{{ 'g03.svg' | asset_url }}" alt="" />
  <div class="wrap">
    <div class="method__head">
      <div>
        <div class="eyebrow"><span class="dot"></span>Metodo</div>
        <h2 class="h-display">Quattro <span class="it" style="color:var(--accent)">tempi</span>.<br>Un solo metodo.</h2>
      </div>
      <p class="sub">Niente trucchi, nessuna scorciatoia. Un processo trasparente che parte dall'ascolto e arriva al cambiamento.</p>
    </div>
    <div class="method__grid">
      <article class="mcard"><img class="mcard__decor" src="{{ 'g06.svg' | asset_url }}" alt="" /><div class="mcard__top"><span class="mcard__n">— 01</span><img class="mcard__icon" src="{{ 'i18.svg' | asset_url }}" alt="" /></div><h3>Ascolto</h3><p>Ogni corpo è una storia. Parto dalla tua: abitudini, allenamenti passati, obiettivi veri.</p></article>
      <article class="mcard"><img class="mcard__decor" src="{{ 'g05.svg' | asset_url }}" alt="" /><div class="mcard__top"><span class="mcard__n">— 02</span><img class="mcard__icon" src="{{ 'i20.svg' | asset_url }}" alt="" /></div><h3>Valutazione</h3><p>Test posturali, mobilità, forza. Online o in studio, per mappare con precisione il punto di partenza.</p></article>
      <article class="mcard"><img class="mcard__decor" src="{{ 'g12.svg' | asset_url }}" alt="" /><div class="mcard__top"><span class="mcard__n">— 03</span><img class="mcard__icon" src="{{ 'i17.svg' | asset_url }}" alt="" /></div><h3>Piano su misura</h3><p>Un programma cucito addosso a te. Video HD, app dedicata, schede settimanali — niente di generico.</p></article>
      <article class="mcard"><img class="mcard__decor" src="{{ 'g14.svg' | asset_url }}" alt="" /><div class="mcard__top"><span class="mcard__n">— 04</span><img class="mcard__icon" src="{{ 'i16.svg' | asset_url }}" alt="" /></div><h3>Accompagnamento</h3><p>Revisione mensile, chat diretta, adattamenti. Non un programma da seguire — un percorso da fare insieme.</p></article>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 6 · PHILOSOPHY QUOTE ───────────────── -->
<section class="qscene" id="quote">
  <img class="qscene__sil" src="{{ 'g10.svg' | asset_url }}" alt="" />
  <div class="wrap">
    <div class="script">la mia filosofia</div>
    <blockquote>La <span class="it">consapevolezza</span> è il primo passo del <span class="it">cambiamento</span>.</blockquote>
    <div class="by">Maria · Chinesiologa</div>
  </div>
</section>

<!-- ───────────────── ACT 7 · APP SHOWCASE ───────────────── -->
<section class="section app" id="app">
  <div class="wrap grid">
    <div>
      <div class="eyebrow"><span class="dot"></span>{{ section.settings.app_overline | default: 'App' }}</div>
      <h2 class="h-1">{{ section.settings.app_h2 | default: 'La tua palestra<br><span class="it">in tasca</span>.' }}</h2>
      <p class="lead">{{ section.settings.app_body | default: "Quando attivi un piano ricevi l'app dedicata: video degli esercizi, calendario, log dei progressi e contatto diretto con me." }}</p>
      <ul>
        <li><span></span>{{ section.settings.app_bullet_1 | default: 'Video HD per ogni esercizio' }}</li>
        <li><span></span>{{ section.settings.app_bullet_2 | default: 'Notifiche promemoria personalizzabili' }}</li>
        <li><span></span>{{ section.settings.app_bullet_3 | default: 'Chat diretta con Maria' }}</li>
        <li><span></span>{{ section.settings.app_bullet_4 | default: 'Dashboard progressi settimanali' }}</li>
      </ul>
      <div class="stores">
        <a class="store" href="{{ section.settings.app_appstore_url | default: 'https://apps.apple.com/it/app/maria-la-chinesiologa/id6739415935' }}" target="_blank" rel="noopener"><div class="mono">Disponibile su</div><b>App Store</b></a>
        <a class="store" href="{{ section.settings.app_playstore_url | default: 'https://play.google.com/store/apps/details?id=com.revoo.marialachinesiologa' }}" target="_blank" rel="noopener"><div class="mono">Disponibile su</div><b>Google Play</b></a>
      </div>
    </div>
    <div class="app__phones">
      <div class="app__phone app__phone--1" id="phone1">
        {%- if section.settings.app_phone1 != blank -%}
          {{ section.settings.app_phone1 | image_url: width: 800 | image_tag: alt: 'App — Schermata Allenamento', loading: 'lazy', widths: '300,600,800,1200' }}
        {%- else -%}
          <img src="{{ 'schermata-allenamento.svg' | asset_url }}" alt="App — Schermata Allenamento">
        {%- endif -%}
      </div>
      <div class="app__phone app__phone--2" id="phone2">
        {%- if section.settings.app_phone2 != blank -%}
          {{ section.settings.app_phone2 | image_url: width: 800 | image_tag: alt: 'Progress Tracker', loading: 'lazy', widths: '300,600,800' }}
        {%- else -%}
          <img src="{{ 'progress-tracker.svg' | asset_url }}" alt="Progress Tracker">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 8 · TESTIMONIALS ───────────────── -->
<section class="section">
  <div class="wrap">
    <div class="tst-head"><h2 class="h-1">Cosa dicono di me.</h2><div class="mono" style="color:var(--ink-soft)">04 — Testimonianze</div></div>
    <div class="tst-grid">
      <article class="tst reveal"><div class="mark serif">"</div><p class="text">Maria ha cambiato il modo in cui mi muovo. La valutazione è stata illuminante: ho capito perché avevo dolore al ginocchio.</p><div class="by"><span>Sara C.</span><span>Torino</span></div></article>
      <article class="tst reveal" style="transition-delay:120ms"><div class="mark serif">"</div><p class="text">In tre mesi ho recuperato mobilità che pensavo di aver perso per sempre. L'app è comodissima.</p><div class="by"><span>Luca M.</span><span>Milano</span></div></article>
      <article class="tst reveal" style="transition-delay:240ms"><div class="mark serif">"</div><p class="text">La sessione online sembrava di essere in studio. Approccio professionale, gentile, ma molto preparato.</p><div class="by"><span>Giulia R.</span><span>Online</span></div></article>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 9 · FAQ ───────────────── -->
<section class="section faq" id="faq">
  <div class="wrap grid">
    <div>
      <div class="eyebrow"><span class="dot"></span>05 — FAQ</div>
      <h2 class="h-1">Domande<br><span class="it">frequenti</span>.</h2>
    </div>
    <div id="faqList">
      <div class="faq__item open"><button class="faq__q"><span class="qt serif">Come funziona la valutazione online?</span><span class="pm">+</span></button><div class="faq__a">Riceverai un link per una videocall di 60 minuti, durante la quale faremo anamnesi, alcuni test posturali guidati e definiremo insieme gli obiettivi.</div></div>
      <div class="faq__item"><button class="faq__q"><span class="qt serif">Quanto dura un piano di allenamento?</span><span class="pm">+</span></button><div class="faq__a">I piani partono da 4 settimane fino a 6 mesi, con revisione mensile per adattarli ai tuoi progressi.</div></div>
      <div class="faq__item"><button class="faq__q"><span class="qt serif">Devo avere attrezzatura specifica?</span><span class="pm">+</span></button><div class="faq__a">No. Adattiamo gli esercizi a casa, in palestra o in viaggio. Bastano un tappetino e poco spazio.</div></div>
      <div class="faq__item"><button class="faq__q"><span class="qt serif">Posso disdire o riprogrammare?</span><span class="pm">+</span></button><div class="faq__a">Sì, fino a 24h prima dell'appuntamento senza alcun costo.</div></div>
      <div class="faq__item"><button class="faq__q"><span class="qt serif">È adatto a chi parte da zero?</span><span class="pm">+</span></button><div class="faq__a">Assolutamente sì. La maggior parte dei miei clienti non si è mai allenata in modo strutturato.</div></div>
      <div class="faq__end"></div>
    </div>
  </div>
</section>

<!-- ───────────────── ACT 10 · FINAL CTA ───────────────── -->
<section class="final" id="final">
  <div class="wrap reveal">
    <div class="script">inizia oggi</div>
    <h2 class="h-display">Il tuo corpo<br><span class="it" style="color:var(--accent)">ti sta aspettando</span>.</h2>
    <a href="#booking" class="btn-gold" style="padding:24px 40px">Prenota la tua valutazione →</a>
  </div>
</section>

<!-- ───────────────── FOOTER ───────────────── -->
<footer class="foot">
  <div class="wrap">
    <div class="foot__grid">
      <div class="foot__brand">
        <span class="wordmark"><img src="{{ 'logo-white.png' | asset_url }}" alt="Maria La Chinesiologa" style="height:60px;width:auto" /></span>
        <p>Valutazioni funzionali e piani di allenamento personalizzati. Padova, Bologna, Milano, Torino + online.</p>
      </div>
      <div class="foot__col"><div class="mono">Servizi</div><ul><li><a href="#booking">Valutazione Funzionale</a></li><li><a href="#piani">Piani di Allenamento</a></li><li><a href="#ebook">eBook</a></li></ul></div>
      <div class="foot__col"><div class="mono">Studio</div><ul><li><a href="#chi-sono">Chi sono</a></li><li><a href="#servizi">Metodo</a></li><li><a href="https://app.marialachinesiologa.com/faq.html">FAQ</a></li><li><a href="https://app.marialachinesiologa.com/contatti.html">Contatti</a></li></ul></div>
      <div class="foot__col"><div class="mono">Legale</div><ul><li><a href="https://app.marialachinesiologa.com/privacy.html">Privacy</a></li><li><a href="https://app.marialachinesiologa.com/cookie.html">Cookie</a></li><li><a href="https://app.marialachinesiologa.com/termini.html">Termini &amp; Rimborsi</a></li></ul></div>
    </div>
    <div class="foot__bar"><span>© 2026 Maria La Chinesiologa</span></div>
  </div>
